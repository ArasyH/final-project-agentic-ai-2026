# Template Streamlit Cloud secrets untuk UI Agentic AI IDX30.
# Copy ke Streamlit Cloud UI: App settings → Secrets (bukan commit ke Git).
# Untuk lokal: simpan sebagai `.streamlit/secrets.toml` di root project.

GROQ_API_KEY = "gsk_..."
SECTORS_API_KEY = "..."

LANGFUSE_PUBLIC_KEY = "pk-lf-..."
LANGFUSE_SECRET_KEY = "sk-lf-..."
LANGFUSE_HOST = "https://cloud.langfuse.com"

# Path ChromaDB di container Streamlit Cloud (writable ephemeral)
CHROMA_DB_PATH = "/tmp/chroma_db"

# Optional: model overrides (default sudah frozen di app/config.py)
# GROQ_GENERATOR_MODEL = "llama-3.1-8b-instant"
# GROQ_CRITIC_MODEL = "llama-3.3-70b-versatile"
